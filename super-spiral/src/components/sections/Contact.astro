---
import { site } from '../../data/site'; const endpoint=import.meta.env.PUBLIC_CONTACT_FORM_ENDPOINT || '';
---
<section class="section shell contact" id="contact"><div class="contact-intro"><p class="eyebrow">¿Tienes un producto o una idea por construir?</p><h1 class="section-title">Creemos algo<br/><em>que funcione.</em></h1><p>Disponible para desarrollo frontend, diseño de interfaces y productos digitales.</p><div><a href={`mailto:${site.email}`}>{site.email}</a><button type="button" data-copy-email={site.email}>Copiar email</button></div></div><form method="POST" action={endpoint || `mailto:${site.email}`} data-contact-form><input class="honeypot" type="text" name="company" tabindex="-1" autocomplete="off" aria-hidden="true"/><label>Nombre<input required name="name" autocomplete="name"/></label><label>Email<input required type="email" name="email" autocomplete="email"/></label><div class="fields"><label>Tipo de proyecto<select name="projectType"><option>Producto digital</option><option>Diseño web</option><option>Aplicación frontend</option><option>Sistema de diseño</option><option>Otro</option></select></label><label>Presupuesto aproximado<select name="budget"><option>Por conversar</option><option>$1k—$5k</option><option>$5k—$15k</option><option>$15k+</option></select></label></div><label>Cuéntame sobre tu idea<textarea required name="message" rows="5" minlength="20"></textarea></label><button class="button button--acid" type="submit">Enviar consulta ↗</button><p class="form-status" data-form-status aria-live="polite"></p></form></section>
<style>.contact{display:grid;grid-template-columns:1.1fr .9fr;gap:8vw;padding-top:calc(var(--header) + 5rem)}.contact-intro em{font-family:serif;color:var(--acid);font-weight:400}.contact-intro>p{color:var(--muted);max-width:34rem;font-size:1.15rem}.contact-intro>div{margin-top:3rem;display:flex;align-items:center;gap:1rem}.contact-intro>div a{font-size:clamp(1.1rem,2vw,1.8rem);border-bottom:1px solid var(--acid)}.contact-intro button{border:0;background:none;color:var(--muted);font-size:.7rem;text-transform:uppercase}.contact form{align-self:end}.contact label{display:block;text-transform:uppercase;font-size:.65rem;letter-spacing:.12em;color:var(--muted);margin-bottom:1.5rem}.contact input,.contact textarea,.contact select{display:block;width:100%;border:0;border-bottom:1px solid var(--line);background:transparent;padding:1rem 0;outline:0;text-transform:none;letter-spacing:normal;color:var(--ink)}.contact select option{background:var(--surface)}.contact input:focus,.contact textarea:focus,.contact select:focus{border-color:var(--acid)}.fields{display:grid;grid-template-columns:1fr 1fr;gap:2rem}.honeypot{position:absolute!important;left:-9999px!important}.form-status{min-height:1.5rem;color:var(--acid)}@media(max-width:800px){.contact{grid-template-columns:1fr}.fields{grid-template-columns:1fr}}
</style>
