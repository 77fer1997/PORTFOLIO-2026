---
import ThreeScene from '../three/ThreeScene.astro'; import { site } from '../../data/site';
---
<section class="hero shell"><ThreeScene/><div class="hero-top"><span>{site.name}</span><span>{site.location}</span><span>Portfolio / 2026</span></div><div class="hero-main"><p class="eyebrow">Código, diseño y producto.</p><h1 class="display"><span>Developer.</span><span>Diseño.</span><span>Producto.</span></h1></div><div class="hero-bottom"><p>{site.description}</p><div><a class="button button--acid" href="#work">Ver proyectos ↓</a><a class="button" href="/contact/">Hablemos ↗</a></div><span class="scroll">Desliza para entrar</span></div></section>
<style>.hero{position:relative;min-height:100svh;padding-top:calc(var(--header) + 1rem);padding-bottom:2rem;display:flex;flex-direction:column;justify-content:space-between}.hero-top{display:grid;grid-template-columns:1fr 1fr auto;position:relative;z-index:1;text-transform:uppercase;font-size:.65rem;letter-spacing:.12em;color:var(--muted)}.hero-main{position:relative;z-index:1;margin-block:auto}.display span{display:block;width:max-content}.display span:nth-child(2){margin-left:13vw;color:var(--acid)}.display span:nth-child(3){margin-left:4vw}.hero-bottom{position:relative;z-index:1;display:grid;grid-template-columns:minmax(15rem,30rem) 1fr auto;gap:2rem;align-items:end}.hero-bottom p{margin:0;font-size:clamp(1.05rem,1.5vw,1.45rem)}.hero-bottom>div{display:flex;gap:.7rem}.scroll{writing-mode:vertical-rl;text-transform:uppercase;font-size:.58rem;letter-spacing:.14em;color:var(--muted)}@media(max-width:760px){.hero-top{grid-template-columns:1fr auto}.hero-top span:nth-child(2){display:none}.hero-main{margin-block:7rem 3rem}.display span:nth-child(2){margin-left:5vw}.display span:nth-child(3){margin-left:0}.hero-bottom{grid-template-columns:1fr}.hero-bottom>div{flex-direction:column}.scroll{display:none}}</style>
