---
const principles=[['01','Comprender a fondo.','Escuchar la necesidad real, incluso aquello que todavía no se ha dicho.'],['02','Construir con intención.','Hacer que cada decisión técnica y visual tenga un propósito.'],['03','Comunicar con claridad.','Convertir la complejidad en algo legible, humano y útil.']];
---
<section class="section shell principles"><p class="eyebrow">Principios de trabajo</p>{principles.map(([n,title,copy])=><article data-reveal><span>{n}</span><h2>{title}</h2><p>{copy}</p></article>)}</section><style>.principles article{display:grid;grid-template-columns:.4fr 2fr 1fr;gap:3rem;align-items:center;border-top:1px solid var(--line);padding:2rem 0}.principles article:first-of-type{margin-top:5rem}.principles span{color:var(--acid)}.principles h2{font-size:clamp(2.5rem,5vw,5rem);font-weight:400;letter-spacing:-.06em;margin:0}.principles p{color:var(--muted);max-width:22rem}@media(max-width:700px){.principles article{grid-template-columns:auto 1fr}.principles p{grid-column:2}}</style>
