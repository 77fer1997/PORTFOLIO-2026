---
import { disciplines } from '../../data/disciplines';
---
<section id="profile" class="section shell disciplines"><p class="eyebrow">Perfil / 01—03</p><h2 class="section-title" data-reveal>Una identidad.<br/><span>Tres perspectivas.</span></h2><div class="discipline-list">{disciplines.map((item)=><article data-reveal><div><strong>{item.number}</strong><span>{item.name}</span></div><h3>{item.description}</h3><ul>{item.topics.map(topic=><li>{topic}</li>)}</ul></article>)}</div></section>
<style>.disciplines .section-title span{color:var(--muted)}.discipline-list{margin-top:5rem}.discipline-list article{display:grid;grid-template-columns:1fr 2fr 1.2fr;gap:4vw;padding:2.5rem 0;border-top:1px solid var(--line)}.discipline-list article>div{display:flex;gap:1.5rem;align-items:start}.discipline-list strong{font-size:clamp(3rem,6vw,6rem);font-weight:400;line-height:.8;color:var(--acid)}.discipline-list article:nth-child(2) strong{color:var(--coral)}.discipline-list h3{font-size:clamp(1.5rem,2.6vw,2.8rem);font-weight:400;letter-spacing:-.04em;margin:0}.discipline-list ul{list-style:none;margin:0;padding:0;color:var(--muted);columns:2}.discipline-list li{margin-bottom:.4rem}@media(max-width:760px){.discipline-list article{grid-template-columns:1fr;gap:2rem}.discipline-list ul{columns:2}}</style>
