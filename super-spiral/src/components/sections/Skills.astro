---
import { skillGroups } from '../../data/disciplines'; const skills=Object.values(skillGroups).flat();
---
<section class="section skills"><p class="eyebrow shell">Herramientas, métodos e instinto</p><div class="marquee" tabindex="0" aria-label={skills.join(', ')}><div aria-hidden="true">{[...skills,...skills].map(skill=><span>{skill} <i>✦</i></span>)}</div></div><div class="skill-groups shell">{Object.entries(skillGroups).map(([group,items])=><div data-reveal><h3>{group}</h3><p>{items.join(' · ')}</p></div>)}</div></section>
<style>.marquee{overflow:hidden;margin-block:4rem 6rem;border-block:1px solid var(--line);padding:1rem 0}.marquee>div{display:flex;width:max-content;animation:marquee 35s linear infinite}.marquee:hover>div,.marquee:focus>div{animation-play-state:paused}.marquee span{font-size:clamp(2rem,5vw,5rem);letter-spacing:-.04em;white-space:nowrap}.marquee i{font-style:normal;color:var(--acid);margin:0 1.2rem}@keyframes marquee{to{transform:translateX(-50%)}}.skill-groups{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:var(--line)}.skill-groups>div{background:var(--bg);padding:1.5rem}.skill-groups h3{font-size:.7rem;text-transform:uppercase;letter-spacing:.12em;color:var(--acid)}.skill-groups p{color:var(--muted);line-height:1.8}@media(max-width:800px){.skill-groups{grid-template-columns:1fr 1fr}}@media(prefers-reduced-motion:reduce){.marquee>div{animation:none}}
</style>
