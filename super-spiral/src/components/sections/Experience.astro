---
import type { CollectionEntry } from 'astro:content'; interface Props { items: CollectionEntry<'experience'>[] } const { items } = Astro.props;
---
<section id="journey" class="section shell journey"><p class="eyebrow">Trayectoria seleccionada</p><h2 class="section-title" data-reveal>Experiencia técnica.<br/>Criterio visual.</h2><div class="timeline">{items.map(item=><article data-reveal><time>{item.data.date}</time><div><span>{item.data.category}</span><h3>{item.data.role}</h3><p>{item.data.institution}</p></div><p>{item.data.description}</p></article>)}</div></section>
<style>.timeline{margin-top:5rem;border-left:1px solid var(--line);margin-left:10vw}.timeline article{position:relative;display:grid;grid-template-columns:.7fr 1fr 1.2fr;gap:3rem;padding:0 0 4rem 3rem}.timeline article::before{content:"";position:absolute;left:-.38rem;top:.4rem;width:.7rem;height:.7rem;border-radius:50%;background:var(--acid)}.timeline time,.timeline span{font-size:.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--muted)}.timeline h3{font-size:1.6rem;font-weight:400;margin:.5rem 0}.timeline p{margin:0;color:var(--muted)}@media(max-width:700px){.timeline{margin-left:.4rem}.timeline article{grid-template-columns:1fr;padding-left:2rem;gap:1rem}}</style>
