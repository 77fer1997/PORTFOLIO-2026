<div class="cursor" data-cursor aria-hidden="true"><span>Ver</span></div><style>.cursor{position:fixed;z-index:999;top:0;left:0;width:1rem;height:1rem;border-radius:50%;background:var(--acid);pointer-events:none;opacity:0;display:grid;place-items:center;transform:translate(-50%,-50%);transition:width .3s,height .3s,opacity .2s}.cursor span{opacity:0;color:var(--bg);font-size:.65rem;text-transform:uppercase}.cursor.is-active{width:5rem;height:5rem}.cursor.is-active span{opacity:1}@media(pointer:coarse),(prefers-reduced-motion:reduce){.cursor{display:none}}</style>
