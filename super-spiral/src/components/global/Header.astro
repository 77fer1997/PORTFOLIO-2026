---
import { navigation, site } from '../../data/site';
---
<header class="header" data-header>
  <a class="brand" href="/" aria-label={`${site.name}, inicio`}><span>{site.shortName}</span><small>{site.role}</small></a>
  <nav class="desktop-nav" aria-label="Navegación principal">{navigation.map((item) => <a href={item.href}>{item.label}</a>)}</nav>
  <div class="available"><i></i><span>Disponible</span></div>
  <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-menu"><span>Menú</span></button>
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true"><nav aria-label="Navegación móvil">{navigation.map((item, i) => <a href={item.href}><small>0{i+1}</small>{item.label}</a>)}</nav><p>{site.location}<br/>{site.email}</p></div>
</header>
<style>
.header{position:fixed;z-index:100;top:0;left:0;width:100%;height:var(--header);padding:0 var(--pad);display:grid;grid-template-columns:1fr auto 1fr;align-items:center;border-bottom:1px solid transparent;transition:.35s;background:linear-gradient(var(--bg),transparent)}.header.is-scrolled{border-color:var(--line);background:rgba(11,12,11,.9);backdrop-filter:blur(12px)}.brand{display:flex;align-items:center;gap:.7rem;width:max-content}.brand>span{font-size:1.4rem;font-weight:800;letter-spacing:-.08em}.brand small{font-size:.58rem;line-height:1.1;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);max-width:7rem}.desktop-nav{display:flex;gap:clamp(1rem,3vw,3rem);font-size:.75rem;text-transform:uppercase;letter-spacing:.1em}.desktop-nav a{position:relative}.desktop-nav a::after{content:"";position:absolute;left:0;bottom:-.4rem;width:100%;height:1px;background:var(--acid);transform:scaleX(0);transform-origin:right;transition:.3s}.desktop-nav a:hover::after{transform:scaleX(1);transform-origin:left}.available{justify-self:end;display:flex;align-items:center;gap:.6rem;text-transform:uppercase;font-size:.66rem;letter-spacing:.1em}.available i{width:.5rem;height:.5rem;border-radius:50%;background:var(--acid);box-shadow:0 0 0 .25rem rgba(199,255,68,.12)}.menu-toggle,.mobile-menu{display:none}
@media(max-width:760px){.header{grid-template-columns:1fr auto}.desktop-nav,.available{display:none}.menu-toggle{display:block;background:none;border:0;text-transform:uppercase;font-size:.7rem;letter-spacing:.15em;z-index:2}.mobile-menu{display:flex;position:fixed;inset:0;z-index:1;background:var(--acid);color:var(--bg);padding:8rem var(--pad) 3rem;flex-direction:column;justify-content:space-between;transform:translateY(-100%);visibility:hidden;transition:.6s var(--ease)}.mobile-menu.is-open{transform:none;visibility:visible}.mobile-menu nav{display:flex;flex-direction:column}.mobile-menu a{font-size:clamp(3rem,16vw,5rem);letter-spacing:-.07em;line-height:1;border-bottom:1px solid rgba(11,12,11,.25)}.mobile-menu a small{font-size:.65rem;letter-spacing:.1em;margin-right:1rem}.mobile-menu p{font-size:.8rem;text-transform:uppercase}.header:has(.is-open) .brand,.header:has(.is-open) .menu-toggle{color:var(--bg)}}
</style>
