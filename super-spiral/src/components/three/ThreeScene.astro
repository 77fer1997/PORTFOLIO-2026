<div class="scene" data-three aria-hidden="true"><div class="fallback"><i></i><i></i><i></i></div></div>
<style>.scene{position:absolute;inset:0 0 0 48%;overflow:hidden;opacity:.9}.scene canvas{width:100%;height:100%}.fallback{position:absolute;inset:15%;display:grid;place-items:center;animation:turn 24s linear infinite}.fallback i{position:absolute;width:min(35vw,30rem);aspect-ratio:1;border:1px solid var(--line);border-radius:50%}.fallback i:nth-child(2){transform:rotate(60deg) scaleX(.35);border-color:var(--acid)}.fallback i:nth-child(3){transform:rotate(-60deg) scaleX(.35);border-color:var(--coral)}@keyframes turn{to{transform:rotate(360deg)}}@media(max-width:760px){.scene{inset:8% -35% 35% 35%;opacity:.55}}@media(prefers-reduced-motion:reduce){.fallback{animation:none}}</style>
