---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
interface Props { projects: CollectionEntry<'projects'>[]; }
const { projects } = Astro.props;
---
<div class="projects-list">{projects.map((project,i)=><article class="project" data-project data-reveal><a href={`/projects/${project.data.slug}/`} aria-label={`Ver caso de estudio: ${project.data.title}`}><div class="project-index">{String(i+1).padStart(2,'0')}<span>{project.data.year}</span></div><div class="project-copy"><p>{project.data.category}</p><h3>{project.data.title}</h3><p>{project.data.excerpt}</p><ul>{project.data.technologies.map(tech=><li>{tech}</li>)}</ul></div><div class="project-image"><Picture src={project.data.cover} alt={project.data.coverAlt} widths={[480,800]} sizes="(max-width: 760px) 100vw, 38vw" formats={['avif','webp']} /></div><span class="project-arrow">↗</span></a></article>)}</div>
<style>.project{border-top:1px solid var(--line)}.project:last-child{border-bottom:1px solid var(--line)}.project>a{position:relative;display:grid;grid-template-columns:.5fr 1.2fr 1fr auto;gap:3vw;padding:2rem 0;align-items:center;min-height:19rem}.project-index{align-self:start;font-size:clamp(2rem,4vw,4rem);font-weight:300;color:var(--muted)}.project-index span{display:block;font-size:.65rem;letter-spacing:.1em;margin-top:1rem}.project-copy h3{font-size:clamp(2.5rem,5vw,5.5rem);font-weight:400;letter-spacing:-.06em;line-height:.9;margin:.5rem 0 1.2rem}.project-copy>p{max-width:30rem;color:var(--muted)}.project-copy>p:first-child{text-transform:uppercase;font-size:.65rem;letter-spacing:.12em;color:var(--acid)}.project-copy ul{list-style:none;padding:0;display:flex;flex-wrap:wrap;gap:.5rem}.project-copy li{border:1px solid var(--line);padding:.3rem .55rem;font-size:.65rem;text-transform:uppercase}.project-image{overflow:hidden}.project-image img{width:100%;aspect-ratio:16/10;object-fit:cover;transition:.7s var(--ease)}.project:hover img{transform:scale(1.04)}.project-arrow{font-size:1.5rem}@media(max-width:760px){.project>a{grid-template-columns:auto 1fr;min-height:0}.project-index{font-size:1.5rem}.project-copy h3{font-size:3rem}.project-image{grid-column:1/-1}.project-arrow{position:absolute;right:0;top:2rem}}</style>
