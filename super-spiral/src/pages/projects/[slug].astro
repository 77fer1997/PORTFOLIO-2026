---
import { getCollection, render } from 'astro:content';
import { Picture } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
export async function getStaticPaths(){const projects=(await getCollection('projects')).sort((a,b)=>a.data.order-b.data.order);return projects.map((project,index)=>({params:{slug:project.data.slug},props:{project,previous:projects[(index-1+projects.length)%projects.length],next:projects[(index+1)%projects.length]}}))}
const {project,previous,next}=Astro.props; const {Content}=await render(project);
const schema={'@context':'https://schema.org','@type':'CreativeWork',name:project.data.title,description:project.data.description,dateCreated:String(project.data.year),creator:{'@type':'Person',name:'Luis Calcina'}};
---
<BaseLayout title={project.data.title} description={project.data.description} schema={schema}>
<article class="case"><header class="case-hero shell"><p class="eyebrow">{project.data.category} / {project.data.year}</p><h1>{project.data.title}</h1><p class="lead">{project.data.description}</p><dl><div><dt>Role</dt><dd>{project.data.role}</dd></div><div><dt>Client</dt><dd>{project.data.client ?? 'Independent'}</dd></div><div><dt>Duration</dt><dd>{project.data.duration ?? '—'}</dd></div></dl></header>
<div class="cover shell"><Picture src={project.data.cover} alt={project.data.coverAlt} widths={[800,1200,1600]} sizes="100vw" formats={['avif','webp']} loading="eager" /></div>
<div class="case-body shell"><aside><p class="eyebrow">Caso de estudio</p><h2>De la pregunta<br/>al resultado.</h2></aside><div class="prose"><section><span>01 / Problema</span><h2>{project.data.problem}</h2></section><section><span>02 / Objetivos</span><ul>{project.data.objectives.map((item:string)=><li>{item}</li>)}</ul></section><section><span>03 / Proceso</span><Content/></section><section><span>04 / Solución</span><h2>{project.data.solution}</h2></section><section><span>05 / Resultados</span><ul>{project.data.results.map((item:string)=><li>{item}</li>)}</ul></section></div></div>
{project.data.gallery?.length && <section class="gallery shell" aria-labelledby="gallery-title"><div class="gallery-heading"><p class="eyebrow">Interfaz del producto</p><h2 id="gallery-title">Diseño aplicado.<br/>Producto real.</h2></div>{project.data.gallery.map((image,index)=><figure><Picture src={image} alt={project.data.galleryAlt?.[index] ?? `Vista ${index+1} del proyecto ${project.data.title}`} widths={[800,1200,1600]} sizes="(max-width: 760px) 100vw, 85vw" formats={['avif','webp']} loading="lazy"/><figcaption>{String(index+1).padStart(2,'0')} / {project.data.galleryCaptions?.[index] ?? 'Interfaz del producto'}</figcaption></figure>)}</section>}
<style>.gallery{padding-bottom:9rem}.gallery-heading{display:grid;grid-template-columns:1fr 2fr;gap:4rem;align-items:start;margin-bottom:5rem}.gallery-heading h2{font-size:clamp(2.5rem,6vw,6rem);font-weight:400;letter-spacing:-.06em;line-height:.9;margin:0}.gallery figure{margin:0 0 clamp(3rem,7vw,7rem)}.gallery picture,.gallery img{display:block;width:100%}.gallery img{border:1px solid var(--line)}.gallery figcaption{margin-top:1rem;color:var(--muted);font-size:.68rem;text-transform:uppercase;letter-spacing:.12em}@media(max-width:700px){.gallery-heading{grid-template-columns:1fr;gap:1rem}.gallery{padding-bottom:5rem}}</style>
<nav class="case-nav shell" aria-label="Navegación de proyectos"><a href={`/projects/${previous.data.slug}/`}><small>Anterior</small>← {previous.data.title}</a><a href={`/projects/${next.data.slug}/`}><small>Siguiente</small>{next.data.title} →</a></nav></article></BaseLayout>
<style>.case-hero{padding-top:calc(var(--header) + 7rem)}.case-hero h1{font-size:clamp(4rem,13vw,13rem);font-weight:400;letter-spacing:-.08em;line-height:.8;margin:4rem 0 2rem}.lead{font-size:clamp(1.3rem,2.3vw,2.3rem);max-width:52rem;margin-left:auto}.case-hero dl{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin:6rem 0 3rem;border-top:1px solid var(--line);padding-top:1rem}.case-hero dt,.case-body span{font-size:.65rem;text-transform:uppercase;letter-spacing:.12em;color:var(--muted)}.case-hero dd{margin:.5rem 0}.cover img{width:100%;max-height:80vh;object-fit:cover}.case-body{display:grid;grid-template-columns:.8fr 1.2fr;gap:8vw;padding-block:9rem}.case-body aside h2{font-size:clamp(2rem,4vw,4rem);font-weight:400;letter-spacing:-.05em}.prose section{padding-bottom:5rem;margin-bottom:5rem;border-bottom:1px solid var(--line)}.prose h2,.prose :global(h2){font-size:clamp(1.7rem,3vw,3rem);font-weight:400;letter-spacing:-.04em}.prose :global(p),.prose li{font-size:1.15rem;color:var(--muted);line-height:1.8}.case-nav{display:grid;grid-template-columns:1fr 1fr;border-top:1px solid var(--line);padding-block:3rem 8rem}.case-nav a{font-size:clamp(1.4rem,3vw,3rem)}.case-nav a:last-child{text-align:right}.case-nav small{display:block;font-size:.6rem;text-transform:uppercase;color:var(--muted)}@media(max-width:700px){.case-hero dl,.case-body{grid-template-columns:1fr}.case-body{padding-block:5rem}.case-nav{gap:1rem}.case-nav a{font-size:1.1rem}}</style>
