---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Página no encontrada" description="Esta página no existe."><section class="lost shell"><p class="eyebrow">Error / 404</p><h1>Ruta equivocada.<br/><span>Buen punto de partida.</span></h1><p>El enlace que buscabas cambió de lugar o ya no existe.</p><a class="button button--acid" href="/">Volver al inicio ↗</a></section></BaseLayout><style>.lost{min-height:100svh;padding-top:calc(var(--header) + 8rem)}.lost h1{font-size:clamp(4rem,13vw,13rem);font-weight:400;letter-spacing:-.08em;line-height:.82}.lost h1 span{color:var(--acid)}.lost p{color:var(--muted)}</style>
